{
	"name": "garden",
	"version": "1.0.0",
	"author": "Maël Lhoutellier <mlhoutel@gmail.com>",
	"license": "MPL",
	"type": "module",
	"scripts": {
		"start": "npm run preprocess && vite dev",
		"build": "npm run preprocess && vite build",
		"package": "vite package",
		"preview": "vite preview",
		"lint": "prettier --check --plugin-search-dir=. . && eslint --ignore-path .gitignore .",
		"format": "prettier --write --plugin-search-dir=. .",
		"content:init": "npm run content:submodule && git submodule update --init --recursive",
		"content:update": "git submodule update --remote --merge",
		"content:status": "git submodule status",
		"content:build": "ts-node --skip-project scripts/build-content.ts",
		"content:manifest": "ts-node --skip-project scripts/build-manifest.ts",
		"content:searchindex": "ts-node --skip-project scripts/build-searchindex.ts",
		"content:images": "ts-node --skip-project scripts/build-images.ts",
		"content:submodule": "ts-node --skip-project scripts/setup-submodule.ts",
		"preprocess": "npm run content:update && npm run content:build && npm run content:images && npm run content:manifest && npm run content:searchindex",
		"setup": "npm install && npm run content:init && npm run preprocess"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-drag": "^3.0.7",
		"@types/d3-force": "^3.0.10",
		"@types/d3-selection": "^3.0.11",
		"@types/d3-transition": "^3.0.9",
		"@types/node": "^25.5.0",
		"@types/seedrandom": "^3.0.8",
		"autoprefixer": "^10.4.21",
		"d3": "^7.9.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"flexsearch": "^0.8.212",
		"globals": "^17.4.0",
		"gray-matter": "^4.0.3",
		"katex": "^0.16.25",
		"material-icons": "^1.13.14",
		"mermaid": "^11.12.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-citation": "^2.3.1",
		"rehype-katex": "^7.0.1",
		"rehype-mathjax": "^7.1.0",
		"rehype-pretty-code": "^0.14.1",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-breaks": "^4.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"remark-smartypants": "^3.0.2",
		"sass": "^1.93.2",
		"seedrandom": "^3.0.5",
		"sharp": "^0.34.5",
		"shiki": "^4.0.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.44.1",
		"unified": "^11.0.5",
		"uuid": "^13.0.0",
		"vite": "^8.0.2",
		"yaml": "^2.8.1"
	},
	"dependencies": {
		"@rehype-pretty/transformers": "^0.13.2",
		"beautiful-mermaid": "^1.1.3",
		"d3-drag": "^3.0.0",
		"d3-force": "^3.0.0",
		"d3-selection": "^3.0.0",
		"d3-transition": "^3.0.1"
	}
}
